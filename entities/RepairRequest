{
  "name": "RepairRequest",
  "type": "object",
  "properties": {
    "request_number": {
      "type": "string",
      "title": "Request Number"
    },
    "asset_id": {
      "type": "string",
      "title": "Asset ID"
    },
    "asset_name": {
      "type": "string",
      "title": "Asset Name"
    },
    "asset_code": {
      "type": "string",
      "title": "Asset Code"
    },
    "school_id": {
      "type": "string",
      "title": "School ID"
    },
    "school_name": {
      "type": "string",
      "title": "School Name"
    },
    "reported_by_email": {
      "type": "string",
      "title": "Reported By"
    },
    "reported_by_name": {
      "type": "string",
      "title": "Reporter Name"
    },
    "description": {
      "type": "string",
      "title": "Damage Description"
    },
    "photo_url": {
      "type": "string",
      "title": "Damage Photo"
    },
    "priority": {
      "type": "string",
      "title": "Priority",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ],
      "default": "Medium"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Pending",
        "Approved",
        "In Progress",
        "Completed",
        "Rejected",
        "Escalated"
      ],
      "default": "Pending"
    },
    "assigned_to_email": {
      "type": "string",
      "title": "Assigned To (Email)"
    },
    "assigned_to_name": {
      "type": "string",
      "title": "Assigned To (Name)"
    },
    "principal_notes": {
      "type": "string",
      "title": "Principal Notes"
    },
    "maintenance_notes": {
      "type": "string",
      "title": "Maintenance Notes"
    },
    "teacher_confirmation": {
      "type": "boolean",
      "title": "Teacher Confirmed Completion",
      "default": false
    },
    "escalated_reason": {
      "type": "string",
      "title": "Escalation Reason"
    },
    "estimated_cost": {
      "type": "number",
      "title": "Estimated Cost (PHP)"
    },
    "completed_date": {
      "type": "string",
      "format": "date",
      "title": "Completion Date"
    }
  },
  "required": [
    "asset_name",
    "description",
    "priority"
  ]
}